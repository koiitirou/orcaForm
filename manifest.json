{
  "manifest_version": 3,
  "name": "ORCA Helper",
  "version": "2.3.0",
  "description": "WebORCAの入力を支援する機能",
  "update_url": "https://storage.googleapis.com/orca-helper-extension/update.xml",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://172.28.22.148/orderconvert/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "sidebar.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://172.28.22.148/orderconvert/*"
      ],
      "js": [
        "debug_panel.js",
        "page_script.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://weborca.cloud.orcamo.jp/*"
      ],
      "js": [
        "orca_helpers.js",
        "orca_rules/rule_820_delete.js",
        "orca_rules/rule_code_replace.js",
        "orca_css.js",
        "orca_sidebar.js",
        "orca_theme.js",
        "orca_rule_engine.js",
        "orca_content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}